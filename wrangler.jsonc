{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "duckduckgo-mcp-codemode",
  "main": "dist/worker.js",
  "compatibility_date": "2025-07-05",
  "compatibility_flags": ["nodejs_compat"],
  "minify": true,
  "observability": { "enabled": true },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ]
}